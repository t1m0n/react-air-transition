{
  "name": "react-air-transition-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter react-air-transition build",
    "build:analyze": "pnpm --filter react-air-transition build:analyze",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky",
    "version:bump": "pnpm --filter react-air-transition version:minor",
    "publish:npm": "pnpm --filter react-air-transition publish:npm",
    "release": "pnpm run version:bump && pnpm run build && pnpm run publish:npm"
  },
  "packageManager": "pnpm@10.12.1",
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react-swc": "catalog:",
    "husky": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9"
  }
}
