{
  "name": "react-air-transition-monorepo",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter react-air-transition build",
    "build:analyze": "pnpm --filter react-air-transition build:analyze",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "husky": "^9.1.7",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9"
  }
}
