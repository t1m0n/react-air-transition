{
  "name": "react-air-transition",
  "version": "1.0.0",
  "description": "React enter/exit animations with anime.js and react-transition-group",
  "type": "module",
  "license": "MIT",
  "author": "t1m0n <t1m0n.tr@gmail.com>",
  "homepage": "https://t1m0n.github.io/react-air-transition/",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/react-air-transition.js",
  "module": "./dist/react-air-transition.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/react-air-transition.js"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:analyze": "cross-env ANALYZE=true vite build && tsc -p tsconfig.build.json",
    "prepack": "node ./scripts/prepack.mjs && pnpm run build",
    "postpack": "node ./scripts/postpack.mjs",
    "version:minor": "pnpm version minor --no-git-tag-version",
    "publish:npm": "pnpm publish --access public --no-git-checks"
  },
  "dependencies": {
    "animejs": "catalog:",
    "react-transition-group": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-transition-group": "catalog:",
    "cross-env": "catalog:",
    "react": "catalog:",
    "rollup-plugin-visualizer": "catalog:",
    "typescript": "catalog:"
  },
  "keywords": [
    "react",
    "animation",
    "transition",
    "animejs",
    "react-transition-group"
  ]
}
